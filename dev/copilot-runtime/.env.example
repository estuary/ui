# Copy to dev/copilot-runtime/.env and fill in ONE provider's key.
# This file is for the LOCAL dev runtime only — the key never reaches the browser.
#
# The runtime auto-selects the provider: if a Gemini/Google key is set it uses
# Gemini, otherwise Anthropic. Set COPILOT_PROVIDER to force one explicitly.

# --- Gemini (Google AI Studio key from https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic (key from https://console.anthropic.com) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Kapa (knowledge retrieval) ---
# Two independent server-side paths; the key never reaches the browser.
#
# 1. Query API — credentials from the Kapa dashboard (API Keys + Integrations
#    tab). Powers the searchEstuaryKnowledge action via the /kapa proxy. Leave
#    any of the three unset to disable it; the rest of the assistant still works.
KAPA_API_KEY=
KAPA_PROJECT_ID=
KAPA_INTEGRATION_ID=
#
# 2. Hosted MCP server (optional) — Kapa's Streamable-HTTP MCP endpoint. When set
#    (with KAPA_API_KEY), the runtime registers it and CopilotKit auto-exposes
#    its tools to the model, using `Authorization: Bearer KAPA_API_KEY`.
#    Use https:// — an http URL 301-redirects and downgrades the POST to GET.
#    e.g. KAPA_MCP_ENDPOINT=https://estuary-int-test.mcp.kapa.ai/
KAPA_MCP_ENDPOINT=

# Optional:
# COPILOT_PROVIDER=google        # force google | anthropic
COPILOT_RUNTIME_PORT=4000
COPILOT_ALLOWED_ORIGIN=http://localhost:3000
# CopilotKit sends anonymous telemetry by default; keep it off for the demo.
COPILOTKIT_TELEMETRY_DISABLED=true
