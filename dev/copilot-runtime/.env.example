# Copy to dev/copilot-runtime/.env and fill in your Anthropic key.
# This file is for the LOCAL dev runtime only — the key never reaches the browser.

ANTHROPIC_API_KEY=
# Optional overrides:
ANTHROPIC_MODEL=claude-opus-4-8
COPILOT_RUNTIME_PORT=4000
COPILOT_ALLOWED_ORIGIN=http://localhost:3000
# CopilotKit sends anonymous telemetry by default; keep it off for the demo.
COPILOTKIT_TELEMETRY_DISABLED=true
